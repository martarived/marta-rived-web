{
  "functions": {
    "api/feed.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/feed", "dest": "/api/feed.js" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.ttf)", "dest": "/$1" },
    { "src": "/(.*\\.jpg|.*\\.jpeg|.*\\.png|.*\\.gif|.*\\.svg|.*\\.ico)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
